pipeline {
    agent any

    environment {
        AWS_REGION     = "us-east-1"
        AWS_ACCOUNT_ID = "471623014951"
        ECR_REPOSITORY = "nodejs-app"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        CLUSTER_NAME   = "aws-prod-cluster"
        NAMESPACE      = "production"
    }

    options {
        timestamps()
        ansiColor('xterm')
    }

    stages {

        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                    echo "===== Git ====="
                    git --version

                    echo "===== Node ====="
                    node -v

                    echo "===== NPM ====="
                    npm -v

                    echo "===== Docker ====="
                    docker --version

                    echo "===== Kubectl ====="
                    kubectl version --client

                    echo "===== AWS CLI ====="
                    aws --version

                    echo "===== Current AWS Identity ====="
                    aws sts get-caller-identity

                    echo "===== Kubernetes Nodes ====="
                    kubectl get nodes
                '''
            }
        }

    }

    post {

        success {
            echo "Pipeline executed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            cleanWs()
        }
    }
}